PORT=3001
NODE_ENV=production

# IMPORTANTE: Usa ruta ABSOLUTA + connection_limit=1 para evitar errores de bloqueo en SQLite
# Para encontrar la ruta absoluta en Hostinger (SSH): realpath prisma/dev.db
DATABASE_URL="file:/RUTA_ABSOLUTA/prisma/dev.db?connection_limit=1"

# JWT — El código requiere estas DOS variables separadas (NO JWT_SECRET)
JWT_ACCESS_SECRET=cambiar_esto_por_algo_seguro_access
JWT_REFRESH_SECRET=cambiar_esto_por_algo_seguro_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

FRONTEND_URL=https://tu-dominio.com
UPLOAD_DIR=./uploads
