# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# IMPORTANTE: ?connection_limit=1 evita errores "database is locked" en SQLite
DATABASE_URL="file:/server/prisma/dev.db?connection_limit=1"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=reemplazar_con_secret_seguro_access
JWT_REFRESH_SECRET=reemplazar_con_secret_seguro_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── ADMIN INICIAL (para seed) ────────────────────────────────────────────────
ADMIN_EMAIL=reemplazar_con_email_admin
ADMIN_PASSWORD=reemplazar_con_password_admin
ADMIN_NAME=Nombre Admin

# ─── EMAIL SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reemplazar_con_email_gmail
SMTP_PASS=reemplazar_con_app_password_de_google
SMTP_FROM=Pedro Vargas Fotografía <reemplazar_con_email_gmail>

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://pedrovargasfotografia.com

# ─── ARCHIVOS ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ─── ARCHIVADO AUTOMÁTICO ─────────────────────────────────────────────────────
BOOKING_ARCHIVE_AFTER_DAYS=180
INVITATION_ARCHIVE_AFTER_DAYS=365
ARCHIVE_SWEEP_INTERVAL_MINUTES=60
